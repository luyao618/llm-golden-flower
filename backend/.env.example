# Golden Flower Poker AI - 环境变量配置
# 复制此文件为 .env 并填入实际的 API Key
#
# 注意：API Key 也可以在前端页面"配置模型"中动态设置（存储在内存中，重启后失效）。
# 如果在 .env 中预配置，则每次启动自动加载，无需重复设置。

# ---- AI Provider API Keys (按需配置) ----
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# SILICONFLOW_API_KEY=your-siliconflow-key-here
# AZURE_OPENAI_API_KEY=your-azure-openai-key-here

# ---- 可选配置 ----
# DEBUG=false
# LLM_TIMEOUT=30
# LLM_MAX_RETRIES=3
# LLM_TEMPERATURE=0.7
